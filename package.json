{
  "name": "mcp-server-dev-test",
  "module": "src/server.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "commit": "git-cz",
    "dev": "bunx @modelcontextprotocol/inspector bun run src/main.ts",
    "dev:stdio": "bunx @modelcontextprotocol/inspector bun run src/local-stdio.ts",
    "dev:server": "bun run src/simpleStreamableHttp.ts",
    "client:test": "bun run src/test-client.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "cz-git": "^1.13.1",
    "tsx": "^4.22.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git",
      "useEmoji": true
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/express": "^5.0.6",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  }
}